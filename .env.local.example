# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe — keys from dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create in Stripe Dashboard → Products
# Product: "Freedom Club Membership"  →  two prices:
#   $10.00 / month  →  copy Price ID here
#   $100.00 / year  →  copy Price ID here
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron job secret — set to a random string, pass as Authorization: Bearer <secret>
CRON_SECRET=your_random_secret_here
